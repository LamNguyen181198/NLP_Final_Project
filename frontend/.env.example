# Flask app settings
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# Default ASR settings
ASR_MODEL_NAME=Qwen/Qwen3-ASR-0.6B
ASR_DEVICE_MAP=cpu
ASR_DTYPE=float32
ASR_MAX_NEW_TOKENS=512

# Translation settings
TRANSLATION_MODEL_PATH=facebook/nllb-200-1.3B
TRANSLATION_SOURCE_LANG=
TRANSLATION_TARGET_LANG=eng_Latn

# Cache settings
# Keep downloaded models on disk between restarts.
HF_HOME=../.hf-cache

# Optional: set true after running the preload script to force local-only model loading.
MODEL_LOCAL_ONLY=true

# Optional: preload ASR + translation into memory at app startup.
# Useful for reducing first-request latency.
PRELOAD_MODELS_ON_STARTUP=true

# Punctuation controls
ENABLE_PUNCTUATION=true
# one of: pre_translation, post_translation, both
PUNCTUATION_STAGE=model
# one of: heuristic, model
PUNCTUATION_STRATEGY=both
